<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT3048_MAUI_Grocery_List.Pages.HouseholdPage"
             Title="Households">

    <Grid RowDefinitions="Auto,*,*">

        
        <VerticalStackLayout Padding="20" Spacing="12" Grid.Row="0">

            <Label x:Name="CurrentUserLabel"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Entry x:Name="HouseholdNameEntry"
                   Placeholder="Enter household name" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Create Household"
                        Clicked="OnCreateHouseholdClicked" />
                <Button Text="Join Household"
                        Clicked="OnJoinHouseholdClicked" />
            </HorizontalStackLayout>

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14"
                   Margin="0,5,0,0" />

            <Label Text="Your Households"
                   FontSize="18"
                   FontAttributes="Bold" />
        </VerticalStackLayout>

        
        <CollectionView x:Name="HouseholdCollectionView"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="OnHouseholdSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="LightGray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,5">
                        <Label Text="{Binding Name}" FontSize="16" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2"
              RowDefinitions="*,Auto"
              Padding="20"
              RowSpacing="10">

            <CollectionView x:Name="MembersCollectionView"
                            Grid.Row="0"
                            HeightRequest="250">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                Padding="10"
                                Margin="0,5">
                            <Label Text="{Binding Username}" FontSize="16" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout Grid.Row="1" Spacing="10">

                <Button Text="View Shared Lists"
                        x:Name="ViewSharedListsButton"
                        Clicked="OnViewSharedListsClicked"
                        Margin="0,10,0,0" />

                <Button Text="Back to Grocery List"
                        Clicked="OnBackClicked" />

            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>