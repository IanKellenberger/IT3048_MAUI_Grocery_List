<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:IT3048_MAUI_Grocery_List.ViewModels"
    x:Class="IT3048_MAUI_Grocery_List.Pages.SavedListsPage">

    <Grid RowDefinitions="Auto,*,*" Padding="20">

        <Label Text="Saved Grocery Lists"
               FontSize="26"
               HorizontalOptions="Center"
               Margin="0,0,0,20"
               Grid.Row="0" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding SavedLists}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedList}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="Gray" StrokeThickness="1" Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding ListName}" FontSize="20" />
                            <Label Text="{Binding CreatedAt, StringFormat='Saved on {0:MM/dd/yyyy}'}"
                                   FontSize="14" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        
        <VerticalStackLayout Grid.Row="2" Spacing="10">

            <Label Text="Items in Selected List"
                   FontSize="22"
                   Margin="0,20,0,10" />

            <CollectionView ItemsSource="{Binding SelectedListItems}"
                            HeightRequest="250">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray" StrokeThickness="1" Padding="8" Margin="3">
                            <HorizontalStackLayout Spacing="15">

                                <CheckBox IsChecked="{Binding IsChecked}" />

                                <Label Text="{Binding ItemName}"
                                       FontSize="18"
                                       VerticalOptions="Center" />

                                <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                       FontSize="18"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />

                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </Grid>
</ContentPage>