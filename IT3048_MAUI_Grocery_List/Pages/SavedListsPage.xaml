<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:IT3048_MAUI_Grocery_List.ViewModels"
    xmlns:services="clr-namespace:IT3048_MAUI_Grocery_List.Services"
    x:Class="IT3048_MAUI_Grocery_List.Pages.SavedListsPage">


    <VerticalStackLayout Padding="20">

        <Label Text="Saved Grocery Lists"
               FontSize="26"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />

        <CollectionView ItemsSource="{Binding SavedLists}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedList}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding ListName}" FontSize="20" />
                            <Label Text="{Binding CreatedAt, StringFormat='Saved on {0:MM/dd/yyyy}'}"
                                   FontSize="14" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="Items in Selected List"
               FontSize="22"
               Margin="0,20,0,10" />

        <CollectionView ItemsSource="{Binding SelectedListItems}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" Padding="8" Margin="3">
                        <HorizontalStackLayout>
                            <Label Text="•" FontSize="18" />
                            <Label Text="{Binding ItemName}" FontSize="18" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
