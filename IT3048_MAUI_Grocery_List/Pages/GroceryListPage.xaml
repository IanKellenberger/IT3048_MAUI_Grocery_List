<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT3048_MAUI_Grocery_List.Pages.GroceryListPage"
             Title="Grocery List">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label x:Name="UsernameLabel"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Entry x:Name="ListNameEntry"
                   Placeholder="Enter list name" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Add Item"
                        Clicked="OnAddItemClicked"
                        HorizontalOptions="FillAndExpand" />
                <Button Text="New List"
                        Clicked="OnNewListClicked"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <CollectionView x:Name="ItemsCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,110,Auto"
                              Padding="0,6">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsChecked}" />

                            <Entry Grid.Column="1"
                                   Text="{Binding Name}"
                                   Placeholder="Item name" />

                            <Entry Grid.Column="2"
                                   Text="{Binding PriceText}"
                                   Placeholder="0.00"
                                   Keyboard="Numeric" />

                            <Button Grid.Column="3"
                                    Text="X"
                                    Clicked="OnDeleteItemClicked" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="TotalLabel"
                   Text="Total: $0.00"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Button Text="Save List"
                    Clicked="OnSaveListClicked" />

            <Button Text="Households"
                    Clicked="OnHouseholdsClicked" />

            <Button Text="Profile"
                    Clicked="OnProfileClicked" />

            <Label x:Name="MessageLabel"
                   TextColor="Red"
                   FontSize="14" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
