<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT3048_MAUI_Grocery_List.Pages.SharedListPage"
             Title="Shared List">

    <VerticalStackLayout Padding="20">

        <CollectionView x:Name="ItemsView"
                        HeightRequest="500">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding IsChecked}" CheckedChanged="OnCheckedChanged" />
                        <Label Text="{Binding ItemName}" />
                        <Label Text="{Binding Price, StringFormat='${0:F2}'}" TextColor="Gray"/>
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Add Item" Clicked="OnAddItemClicked" />

    </VerticalStackLayout>
</ContentPage>