<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT3048_MAUI_Grocery_List.Pages.HouseholdSharedListsPage"
             Title="Shared Lists">

    <Grid RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout Padding="20" Spacing="10" Grid.Row="0">
            <Label Text="Shared Lists"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Button Text="Share a Saved List"
                    x:Name="ShareListButton"
                    Clicked="OnShareListClicked" />
        </VerticalStackLayout>

        <CollectionView x:Name="SharedListsView"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="OnListSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="LightGray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,5">
                        <Label Text="{Binding ListName}" FontSize="18" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Back"
                Grid.Row="2"
                Margin="20"
                Clicked="OnBackClicked" />

    </Grid>
</ContentPage>